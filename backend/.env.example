# Copy this file to .env and fill in your details. Never commit .env.

# EOG (Earth Observation Group) credentials — register at https://eogdata.mines.edu/
# Used by: make download YEAR=2023
EOG_USERNAME=your_username
EOG_PASSWORD=your_password

# NASA Earthdata credentials — register at https://urs.earthdata.nasa.gov/
# Used by: make download-nasa YEAR=2023  (fallback; EOG data preferred)
EARTHDATA_USERNAME=your_username
EARTHDATA_PASSWORD=your_password
